# Environment and secrets
.env
.env.*
!.env.example
config/data_storage.local.json
secrets/
local-data/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
backend/.venv/

# Node / Next.js
node_modules/
.next/
out/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# GIS, CAD, database, and exported data
*.gdb
*.gdb/
*.sde
*.dwg
*.dxf
*.shp
*.dbf
*.shx
*.prj
*.cpg
*.gpkg
*.sqlite
*.tif
*.tiff
*.pdf
*.xlsx
*.xls
*.csv
*.zip
*.7z
*.bak
*.lock
*.sr.lock

# Allow intentional source-code CSV fixtures.
!tests/**/*.csv
!backend/tests/**/*.csv

# Raw or derived production data must stay out of Git.
data/incoming/**
!data/incoming/
!data/incoming/.gitkeep
!data/incoming/cad/
!data/incoming/cad/.gitkeep
!data/incoming/pdf/
!data/incoming/pdf/.gitkeep
!data/incoming/spreadsheets/
!data/incoming/spreadsheets/.gitkeep
!data/incoming/geodatabases/
!data/incoming/geodatabases/.gitkeep
data/staging/**
!data/staging/
!data/staging/.gitkeep
data/processed/**
!data/processed/
!data/processed/.gitkeep

# Sanitized samples may be committed intentionally.
!data/samples/
!data/samples/.gitkeep
!data/samples/**/*.json
!data/samples/**/*.geojson
